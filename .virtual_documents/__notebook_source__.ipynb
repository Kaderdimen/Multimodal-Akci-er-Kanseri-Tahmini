import pandas as pd
from sklearn.preprocessing import LabelEncoder

# Klinik tablonun tam yolu
csv_file_path = '/kaggle/input/datasets/saibhossain/clinical-data-of-nsclc-lungi1/NSCLC-Radiomics-Lung1.clinical-version3-Oct-2019.csv'
df = pd.read_csv(csv_file_path)

# HATA GARANTİSİ: Tüm sütun isimlerini tamamen küçük harfe çeviriyoruz
df.columns = df.columns.str.lower()

# 1. Eksik verileri dolduralım (Sütun adı artık tamamen küçük harf: 'age')
df['age'] = df['age'].fillna(df['age'].mean())

# 2. Kategorik sütunları sayısal verilere dönüştürelim
le_gender = LabelEncoder()
df['gender_encoded'] = le_gender.fit_transform(df['gender'].astype(str))

le_histology = LabelEncoder()
df['histology_encoded'] = le_histology.fit_transform(df['histology'].astype(str))

le_stage = LabelEncoder()
# Sütun adı artık tamamen küçük harf olduğu için doğrudan 'overall.stage' yazıyoruz
df['stage_encoded'] = le_stage.fit_transform(df['overall.stage'].astype(str))

print("🎯 İnatçı hata kırıldı! Klinik veri başarıyla sayısallaştırıldı.")
print("\n--- Model Giriş Matrisi Ön İzleme ---")
# 'patientid' de artık tamamen küçük harf oldu
print(df[['patientid', 'age', 'gender_encoded', 'histology_encoded', 'stage_encoded']].head())


import torch
from torch.utils.data import Dataset, DataLoader
import pydicom
import cv2
import numpy as np
import os

class MultimodalLungDataset(Dataset):
    def __init__(self, clinical_df, img_base_dir, transform=None):
        self.df = clinical_df.reset_index(drop=True)
        self.img_base_dir = img_base_dir
        self.transform = transform

    def __len__(self):
        return len(self.df)

    def _find_valid_dcm(self, patient_id):
        patient_folder_name = str(patient_id).upper()
        patient_dir = os.path.join(self.img_base_dir, patient_folder_name)
        
        if not os.path.exists(patient_dir):
            return None
            
        for root, dirs, files in os.walk(patient_dir):
            for file in files:
                if file.endswith('.dcm'):
                    file_path = os.path.join(root, file)
                    try:
                        ds = pydicom.dcmread(file_path)
                        if 'PixelData' in ds:
                            return file_path
                    except:
                        continue
        return None

    def __getitem__(self, idx):
        row = self.df.iloc[idx]
        patient_id = row['patientid']
        
        dcm_path = self._find_valid_dcm(patient_id)
        
        if dcm_path:
            ds = pydicom.dcmread(dcm_path)
            img = ds.pixel_array.astype(float)
            
            # 📌 HATA ÇÖZÜMÜ: Eğer görüntü 3D veya çok katmanlıysa (örneğin [512, 512, 120] veya [120, 512, 512])
            # Tam ortadaki kesiti alarak 2D'ye indirgiyoruz.
            if len(img.shape) == 3:
                # En küçük boyut katman (slice) sayısıdır, genellikle 0. veya 2. indekstir
                if img.shape[0] < img.shape[2]:
                    mid_idx = img.shape[0] // 2
                    img = img[mid_idx, :, :]
                else:
                    mid_idx = img.shape[2] // 2
                    img = img[:, :, mid_idx]
            
            # Şimdi güvenle Min-Max Normalization yapabiliriz
            img = (img - np.min(img)) / (np.max(img) - np.min(img) + 1e-8)
            # Standart 224x224 boyutlandırma
            img = cv2.resize(img, (224, 224))
            img = torch.tensor(img, dtype=torch.float32).unsqueeze(0) # [1, 224, 224]
        else:
            img = torch.zeros((1, 224, 224), dtype=torch.float32)

        # Klinik Veriler
        clinical_features = np.array([
            row['age'], 
            row['gender_encoded'], 
            row['histology_encoded']
        ], dtype=np.float32)
        
        clinical_tensor = torch.tensor(clinical_features, dtype=torch.float32)
        target = torch.tensor(int(row['stage_encoded']), dtype=torch.long)
        
        return img, clinical_tensor, target

print("🚀 Akıllı Multimodal Dataset sınıfı başarıyla güncellendi!")


