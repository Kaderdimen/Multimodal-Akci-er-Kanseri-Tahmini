import torch
import torch.nn as nn
import torchvision.models as models

class MultimodalCancerModel(nn.Module):
    def __init__(self, num_classes=4):
        super(MultimodalCancerModel, self).__init__()
        
        # 1. Kol: Görüntü İşleme İçin ResNet-18 (Hafif ve güçlü)
        # ResNet normalde 3 kanallı (RGB) resim bekler, bizim tomografiler tek kanallı (Gri).
        # Bu yüzden ilk katmanını 1 kanallı kabul edecek şekilde güncelliyoruz.
        self.cnn = models.resnet18(weights=None)
        self.cnn.conv1 = nn.Conv2d(1, 64, kernel_size=7, stride=2, padding=3, bias=False)
        
        # ResNet'in son sınıflandırma katmanını boşa çıkarıp, görüntüyü 128 boyutlu bir vektöre indirgiyoruz
        cnn_out_features = self.cnn.fc.in_features
        self.cnn.fc = nn.Linear(cnn_out_features, 128)
        
        # 2. Kol: Klinik Veriler İçin Yapay Sinir Ağı (MLP)
        # Girişte 3 özniteliğimiz var (yaş, cinsiyet, histology)
        self.mlp = nn.Sequential(
            nn.Linear(3, 16),
            nn.ReLU(),
            nn.Linear(16, 32),
            nn.ReLU()
        )
        
        # 3. Kol: Füzyon ve Karar Katmanı
        # Görüntüden 128, klinikten 32 boyut geliyor. Toplam: 128 + 32 = 160 boyutlu birleşik vektör.
        self.fusion = nn.Sequential(
            nn.Linear(128 + 32, 64),
            nn.ReLU(),
            nn.Dropout(0.3), # Ezberlemeyi (overfitting) önlemek için %30 nöron siliyoruz
            nn.Linear(64, num_classes) # Son karar katmanı (Sınıf sayısı kadar çıktı)
        )
        
    def forward(self, img, clinical):
        # İki koldan öznitelikleri çıkaralım
        img_features = self.cnn(img)          # Çıktı boyutu: [Batch, 128]
        clinical_features = self.mlp(clinical) # Çıktı boyutu: [Batch, 32]
        
        # Erken Füzyon (Early-Intermediate Fusion): İki vektörü yan yana yapıştırıyoruz
        combined = torch.cat((img_features, clinical_features), dim=1) # Çıktı boyutu: [Batch, 160]
        
        # Birleşik vektörü nihai tahmin için ana ağa gönderiyoruz
        output = self.fusion(combined)
        return output

# Modeli test etmek için nesne oluşturalım
model = MultimodalCancerModel(num_classes=len(df['stage_encoded'].unique()))
print("🎯 Tebrikler! İki kollu Multimodal Yapay Zeka Mimarisi Başarıyla İnşa Edildi.")


import torch.optim as optim
import torch.nn as nn
from torch.utils.data import DataLoader
from sklearn.model_selection import train_test_split

# 1. Donanım Kontrolü
device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"💻 Çalışma Donanımı: {device}")

model = model.to(device)

# 2. HATA ÇÖZÜMÜ: stratify=df['stage_encoded'] parametresini kaldırdık!
train_df, val_df = train_test_split(df, test_size=0.2, random_state=42)

# Eğitim ve Doğrulama için veri hatlarını yeniden kuruyoruz
train_dataset = MultimodalLungDataset(clinical_df=train_df, img_base_dir=images_path)
val_dataset = MultimodalLungDataset(clinical_df=val_df, img_base_dir=images_path)

train_loader = DataLoader(train_dataset, batch_size=8, shuffle=True)
val_loader = DataLoader(val_dataset, batch_size=8, shuffle=False)

# 3. Kayıp Fonksiyonu ve Optimizer Tanımı
criterion = nn.CrossEntropyLoss() 
optimizer = optim.Adam(model.parameters(), lr=0.001) 

# 4. Eğitim Döngüsü (Training Loop) - 5 Epoch (Tur)
epochs = 5

print("\n🚀 Model Eğitimi Resmen Başlıyor...\n")

for epoch in range(epochs):
    model.train() 
    running_loss = 0.0
    correct = 0
    total = 0
    
    for imgs, clinicals, targets in train_loader:
        imgs = imgs.to(device)
        clinicals = clinicals.to(device)
        targets = targets.to(device)
        
        optimizer.zero_grad()
        
        outputs = model(imgs, clinicals)
        loss = criterion(outputs, targets)
        
        loss.backward()
        optimizer.step()
        
        running_loss += loss.item() * imgs.size(0)
        _, predicted = outputs.max(1)
        total += targets.size(0)
        correct += predicted.eq(targets).sum().item()
        
    epoch_loss = running_loss / len(train_loader.dataset)
    epoch_acc = (correct / total) * 100
    
    print(f"Epoch [{epoch+1}/{epochs}] -> Train Loss: {epoch_loss:.4f} | Train Acc: {epoch_acc:.2f}%")

print("\n🎉 İlk deneme eğitimi başarıyla tamamlandı!")

   


from sklearn.metrics import classification_report, confusion_matrix

model.eval() # Modeli test moduna alıyoruz (Dropout katmanlarını kapatır)

all_preds = []
all_targets = []

# Gradyan hesaplamasını kapatıyoruz ki hem bellek yorulmasın hem de işlem hızlı bitsin
with torch.no_grad():
    for imgs, clinicals, targets in val_loader:
        imgs = imgs.to(device)
        clinicals = clinicals.to(device)
        
        # Modelin tahminini alalım
        outputs = model(imgs, clinicals)
        _, predicted = outputs.max(1)
        
        # Sonuçları listeye ekleyelim
        all_preds.extend(predicted.cpu().numpy())
        all_targets.extend(targets.numpy())

print("--- 📊 DOĞRULAMA (VALIDATION) PERFORMANS RAPORU ---")
print(classification_report(all_targets, all_preds, zero_division=0))


import numpy as np
import torch
import torch.nn as nn

# 1. Adım: Eğitim setindeki etiketleri toplayalım
all_train_labels = []
for _, _, labels in train_loader: 
    all_train_labels.extend(labels.numpy())

all_train_labels = np.array(all_train_labels)
total_samples = len(all_train_labels)
num_classes = 5  # Toplam olası sınıf sayımız (0, 1, 2, 3, 4)

# Her sınıftan eğitim setinde kaçar tane olduğunu sayalım (bincount)
counts = np.bincount(all_train_labels, minlength=num_classes)
print("Eğitim Setindeki Sınıf Dağılımları (0'dan 4'e):", counts)

# Sklearn'ün 'balanced' formülünü manuel uyguluyoruz: total_samples / (num_classes * count)
weights = []
for count in counts:
    if count > 0:
        weight = total_samples / (num_classes * count)
    else:
        weight = 1.0  # Eğitim setinde hiç yoksa hata verme, ağırlığını 1.0 yap geç
    weights.append(weight)

weights = np.array(weights)
class_weights = torch.FloatTensor(weights).cuda() 

print("Yeni Manuel Hesaplanan 5 Sınıflı Ağırlıklar:", weights)

# 2. Adım: Kayıp fonksiyonuna ağırlıkları enjekte ediyoruz
criterion = nn.CrossEntropyLoss(weight=class_weights)

# 3. Adım: Modeli ve verileri GPU'ya taşıyoruz
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
model = model.to(device)

print(f"Model başarıyla şu donanım üzerinde çalışıyor: {device}")


import time

# Eğitim parametreleri
num_epochs = 30
best_val_acc = 0.0

print("--- 🚀 GPU VE SINIF AĞIRLIKLI EĞİTİM BAŞLIYOR 🚀 ---")

for epoch in range(num_epochs):
    start_time = time.time()
    
    # --- EĞİTİM ADIMI (TRAINING) ---
    model.train()
    train_loss = 0.0
    correct_train = 0
    total_train = 0
    
    # Hatırlatıcı: Dün yakaladığımız 3'lü veriyi (görüntü, klinik, etiket) GPU'ya taşıyoruz
    for images, clinical_data, labels in train_loader:
        images = images.to(device)
        clinical_data = clinical_data.to(device)
        labels = labels.to(device)
        
        # Gradıentleri sıfırla
        optimizer.zero_grad()
        
        # İleri Besleme (Forward Pass)
        outputs = model(images, clinical_data)
        loss = criterion(outputs, labels)
        
        # Geri Besleme ve Optimizasyon (Backward Pass)
        loss.backward()
        optimizer.step()
        
        train_loss += loss.item() * images.size(0)
        _, predicted = torch.max(outputs.data, 1)
        total_train += labels.size(0)
        correct_train += (predicted == labels).sum().item()
        
    train_epoch_loss = train_loss / len(train_loader.dataset)
    train_acc = (correct_train / total_train) * 100
    
    # --- DOĞRULAMA ADIMI (VALIDATION) ---
    model.eval()
    val_loss = 0.0
    correct_val = 0
    total_val = 0
    
    with torch.no_grad():
        for images, clinical_data, labels in val_loader:
            images = images.to(device)
            clinical_data = clinical_data.to(device)
            labels = labels.to(device)
            
            outputs = model(images, clinical_data)
            loss = criterion(outputs, labels)
            
            val_loss += loss.item() * images.size(0)
            _, predicted = torch.max(outputs.data, 1)
            total_val += labels.size(0)
            correct_val += (predicted == labels).sum().item()
            
    val_epoch_loss = val_loss / len(val_loader.dataset)
    val_acc = (correct_val / total_val) * 100
    epoch_time = time.time() - start_time
    
    # Her 5 turda bir durumu ekrana yazdıralım (Ekranı doldurmasın)
    if (epoch + 1) % 5 == 0 or epoch == 0:
        print(f"Epoch [{epoch+1}/{num_epochs}] ({epoch_time:.1f} sn) -> "
              f"Train Loss: {train_epoch_loss:.4f} | Train Acc: %{train_acc:.2f} || "
              f"Val Loss: {val_epoch_loss:.4f} | Val Acc: %{val_acc:.2f}")

print("--- 🏁 EĞİTİM TAMAMLANDI! 🏁 ---")


